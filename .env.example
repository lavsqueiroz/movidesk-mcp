# ─────────────────────────────────────────────────
# Movidesk MCP — variáveis de ambiente
# Copie para .env e preencha os valores reais
# NUNCA commite o .env com secrets
# ─────────────────────────────────────────────────

# ── Servidor ─────────────────────────────────────
PORT=3457
NODE_ENV=production

# ── JWT (OAuth 2.0 Client Credentials) ───────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UM_SECRET_FORTE_DE_64_BYTES
JWT_EXPIRATION=1h

# ── Client autorizado a obter tokens ─────────────
MCP_CLIENT_ID=movidesk-mcp-client
MCP_CLIENT_SECRET=TROQUE_POR_UM_SECRET_FORTE

# ── Movidesk API ──────────────────────────────────
# Token de acesso da API Movidesk (obrigatório)
MOVIDESK_TOKEN=SEU_TOKEN_MOVIDESK_AQUI

# URL base da sua conta Movidesk (opcional — padrão já configurado no cliente)
# MOVIDESK_BASE_URL=https://api.movidesk.com/public/v1

# ── Webhook (opcional) ────────────────────────────
# Se configurado, valida assinatura HMAC dos eventos recebidos
# MOVIDESK_WEBHOOK_SECRET=
